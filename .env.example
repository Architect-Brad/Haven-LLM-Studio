# Haven LLM Studio - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HAVEN_PORT=1234
HAVEN_HOST=127.0.0.1

# Model Configuration
HAVEN_MODELS_DIR=~/.haven/models

# Development
NODE_ENV=development

# GPU Configuration
# Set to number of layers to offload (0 = CPU only, -1 = all layers)
HAVEN_GPU_LAYERS=0

# Multi-GPU
HAVEN_MULTI_GPU=false

# CPU Optimization
# AVX2: Most x86 CPUs since 2013 (Haswell+)
# AVX512: Server/modern desktop (Skylake-X+, Zen 4+)
# ARM/NEON: Raspberry Pi, Orange Pi, Apple Silicon
# iGPU: Intel UHD/Iris Xe, AMD Radeon Graphics (APU)
HAVEN_CPU_OPT=auto

# CUDA (NVIDIA GPU)
# CUDA_VISIBLE_DEVICES=0

# ROCm (AMD GPU)
# HCC_AMDGPU_TARGET=gfx1100

# Logging
HAVEN_LOG_LEVEL=info

# Cluster Configuration
HAVEN_CLUSTER=false
HAVEN_CLUSTER_ROLE=master        # master or worker
HAVEN_CLUSTER_PORT=1235
HAVEN_CLUSTER_HOST=0.0.0.0
HAVEN_MASTER_URL=ws://192.168.1.100:1235  # For workers
HAVEN_NODE_ID=node-1
HAVEN_NODE_NAME=Haven Node 1
HAVEN_MAX_WORKERS=10
HAVEN_CLUSTER_TOKEN=your-secret-token
