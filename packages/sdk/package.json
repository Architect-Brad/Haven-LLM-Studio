{
  "name": "@haven/sdk",
  "version": "0.1.0",
  "description": "Local AI inference SDK — run LLMs directly in Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "native",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "llm",
    "local-ai",
    "inference",
    "llama-cpp",
    "gguf",
    "native",
    "sdk"
  ],
  "author": "Haven LLM Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Architect-Brad/Haven-LLM-Studio",
    "directory": "packages/sdk"
  }
}
