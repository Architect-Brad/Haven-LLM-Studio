{
  "name": "haven-llm-studio",
  "version": "0.1.0",
  "description": "Local AI inference powerhouse - Run, host, and serve LLMs with state-of-the-art performance",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:app\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:app": "vite --config vite.config.ts",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:core && npm run build:server && npm run build:app",
    "build:core": "cd native && cmake -B build && cmake --build build",
    "build:native-addon": "cd native && node-gyp rebuild",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app": "vite build --config vite.config.ts && electron-builder",
    "build:ui": "vite build --config vite.config.ts",
    "server": "node dist/server/index.js",
    "app:desktop": "electron .",
    "app:mobile:ios": "cd mobile && npm run ios",
    "app:mobile:android": "cd mobile && npm run android",
    "test": "vitest",
    "test:bench": "tsx benchmarks/run.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "postinstall": "cd native && node-gyp configure 2>/dev/null || true"
  },
  "keywords": [
    "llm",
    "local-ai",
    "inference",
    "llama-cpp",
    "gguf",
    "openai-api",
    "ai-server"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "ws": "^8.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "dbus-next": "^0.0.0"
  },
  "build": {
    "appId": "com.havenllm.studio",
    "productName": "Haven LLM Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "native/build/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
